generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  profilePic  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resumes     Resume[]
  skills      UserSkill[]
  jobMatches  JobMatch[]
  roadmaps    Roadmap[]
}

model Resume {
  id          String   @id @default(uuid())
  fileName    String
  fileUrl     String
  atsScore    Int?

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  analyses    ResumeAnalysis[]

  createdAt   DateTime @default(now())
}

model ResumeAnalysis {
  id              String @id @default(uuid())

  grammarScore    Int?
  formattingScore Int?
  keywordScore    Int?

  strengths       String?
  weaknesses      String?

  resumeId        String @unique
  resume          Resume @relation(fields: [resumeId], references: [id])

  createdAt       DateTime @default(now())
}

model Skill {
  id          String @id @default(uuid())
  name        String @unique

  users       UserSkill[]
}

model UserSkill {
  id          String @id @default(uuid())

  level       Int @default(1)

  userId      String
  skillId     String

  user        User @relation(fields: [userId], references: [id])
  skill       Skill @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model Job {
  id           String @id @default(uuid())

  title        String
  company      String
  location     String

  salaryMin    Int?
  salaryMax    Int?

  description  String?

  createdAt    DateTime @default(now())

  matches      JobMatch[]
}

model JobMatch {
  id           String @id @default(uuid())

  matchScore   Int

  userId       String
  jobId        String

  user         User @relation(fields: [userId], references: [id])
  job          Job @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
}

model Roadmap {
  id           String @id @default(uuid())

  title        String

  userId       String
  user         User @relation(fields: [userId], references: [id])

  steps        RoadmapStep[]

  createdAt    DateTime @default(now())
}

model RoadmapStep {
  id           String @id @default(uuid())

  title        String
  description  String?

  status       String @default("PENDING")
  progress     Int    @default(0)

  roadmapId     String
  roadmap       Roadmap @relation(fields: [roadmapId], references: [id])

  createdAt    DateTime @default(now())
}